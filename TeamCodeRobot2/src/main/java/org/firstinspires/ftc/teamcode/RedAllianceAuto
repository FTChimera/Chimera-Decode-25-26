@Autonomous(name="RedAllianceAuto")
public class RedAllianceAuto extends LinearOpMode {

    DcMotorEx OutakeMotorLeft;
    DcMotorEx OutakeMotorRight;
    Servo pushServo;

    public class Launcher implements Action {

        private long startTime;
        private static final long DURATION_MS = 1000; // 1000 milliseconds

        @Override

        public boolean run(@NonNull TelemetryPacket packet) {
            // Start the timer and motors on the first run
            if (startTime == 0) {
                startTime = System.currentTimeMillis();
                OutakeMotorLeft.setPower(0.8);
                OutakeMotorRight.setPower(0.8);
                sleep(200);
                pushServo.setPosition(-1);//Set pushServo to launch
                sleep(1000);

            }

            // Check if the duration has passed
            long elapsedTime = System.currentTimeMillis() - startTime;
            if (elapsedTime >= DURATION_MS) {
                // Stop the motors and end the action
                OutakeMotorLeft.setPower(0);
                OutakeMotorRight.setPower(0);
                pushServo.setPosition(1);//Resets the pushServo position
                sleep(1000);
                return false; // The action is finished

            }
            packet.put("Launcher Status", "Running for " + elapsedTime + "ms");
            return true;


        }
    }

    @Override

    public void runOpMode() throws InterruptedException {

        final DcMotorEx frontLeftMotor, backLeftMotor, backRightMotor, frontRightMotor;

        frontLeftMotor = hardwareMap.get(DcMotorEx.class, "frontLeftMotor");
        backLeftMotor = hardwareMap.get(DcMotorEx.class, "backLeftMotor");
        backRightMotor = hardwareMap.get(DcMotorEx.class, "backRightMotor");
        frontRightMotor = hardwareMap.get(DcMotorEx.class, "frontRightMotor");
        OutakeMotorRight = hardwareMap.get(DcMotorEx.class, "OutakeMotorRight");
        OutakeMotorLeft = hardwareMap.get(DcMotorEx.class, "OutakeMotorLeft");
        pushServo = hardwareMap.servo.get("pushServo");


        frontRightMotor.setDirection(DcMotorSimple.Direction.FORWARD);
        backRightMotor.setDirection(DcMotorSimple.Direction.REVERSE);
        frontLeftMotor.setDirection(DcMotorSimple.Direction.FORWARD);
        backLeftMotor.setDirection(DcMotorSimple.Direction.REVERSE);
        OutakeMotorRight.setDirection(DcMotorSimple.Direction.FORWARD);
        OutakeMotorLeft.setDirection(DcMotorSimple.Direction.REVERSE);

        Pose2d beginPose = new Pose2d(new Vector2d(61, -20), Math.toRadians(0));
        MecanumDrive drive = new MecanumDrive(hardwareMap, beginPose);

        waitForStart();
        //if (isStopRequested()) return;

        //while (opModeIsActive()) {
            telemetry.addData("Message", "Hello World");
            telemetry.update();

            Action path = drive.actionBuilder(beginPose)
                    // First, move to the position (0, 0)
                    .strafeTo(new Vector2d(0, 0))
                    // Then, turn to the final heading
                    .turn(Math.toRadians(315))
                    //Launch the first two balls
                    .stopAndAdd(new Launcher())
                    //Go to Human PLayer zone to grab ball (if hardware doesnt allow us to gather all 3 balls
                    //then we need to go back for more)
                    .splineToSplineHeading(new Pose2d(60, -42, Math.toRadians(90)), Math.toRadians(270))
                    //Go to launching pos to launch more balls
                    .splineToSplineHeading(new Pose2d(0, 0, Math.toRadians(315)), Math.toRadians(200))
                    .stopAndAdd(new Launcher())
                    //If robot cant carry 3 balls go back to human player zone to get one more ball
                    .splineToSplineHeading(new Pose2d(60, -42, Math.toRadians(90)), Math.toRadians(270))
                    //Go to launching pos to launch more balls
                    .splineToSplineHeading(new Pose2d(0, 0, Math.toRadians(315)), Math.toRadians(200))
                    .stopAndAdd(new Launcher())
                    //.splineToSplineHeading(new Pose2d(0, 63, Math.toRadians(180)), Math.toRadians(270))
                    .build();

            Actions.runBlocking(new SequentialAction(path));

        //}

    }
}
